#!/usr/bin/env python3
"""OpenClaw Claude API Cost Tracker

Tracks Claude API token usage and reports metrics to GCP Cloud Monitoring.
Managed by Ansible - do not edit manually.
"""

import json
import logging
import time
import subprocess
from pathlib import Path

try:
    from google.cloud import monitoring_v3
    HAS_CLOUD_MONITORING = True
except ImportError:
    HAS_CLOUD_MONITORING = False

try:
    import anthropic
    HAS_ANTHROPIC = True
except ImportError:
    HAS_ANTHROPIC = False

# Configuration
SECRETS_DIR = "{{ secrets_dir }}"
GCP_PROJECT_ID = "{{ gcp_project_id }}"
INTERVAL = {{ cost_tracker_interval }}
LOG_FILE = "{{ cost_tracker_log }}"

# Claude API pricing (per million tokens, as of 2024)
PRICING = {
    "claude-3-opus": {"input": 15.0, "output": 75.0},
    "claude-3-sonnet": {"input": 3.0, "output": 15.0},
    "claude-3-haiku": {"input": 0.25, "output": 1.25},
    "claude-3.5-sonnet": {"input": 3.0, "output": 15.0},
    "claude-4-sonnet": {"input": 3.0, "output": 15.0},
}

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.FileHandler(LOG_FILE),
        logging.StreamHandler(),
    ],
)
logger = logging.getLogger(__name__)


def read_api_key():
    """Read the Anthropic API key from the secrets file."""
    key_path = Path(SECRETS_DIR) / "anthropic_api_key"
    return key_path.read_text().strip()


def get_token_usage_from_logs():
    """Estimate token usage from Docker container logs."""
    try:
        result = subprocess.run(
            ["docker", "logs", "--since", f"{INTERVAL}s", "openclaw"],
            capture_output=True, text=True, timeout=30,
        )
        input_tokens = 0
        output_tokens = 0
        for line in result.stdout.splitlines():
            if "input_tokens" in line:
                try:
                    data = json.loads(line)
                    input_tokens += data.get("input_tokens", 0)
                    output_tokens += data.get("output_tokens", 0)
                except (json.JSONDecodeError, KeyError):
                    continue
        return input_tokens, output_tokens
    except (subprocess.TimeoutExpired, FileNotFoundError) as e:
        logger.warning("Failed to read container logs: %s", e)
        return 0, 0


def estimate_cost(input_tokens, output_tokens, model="claude-3.5-sonnet"):
    """Estimate cost based on token usage and model pricing."""
    pricing = PRICING.get(model, PRICING["claude-3.5-sonnet"])
    input_cost = (input_tokens / 1_000_000) * pricing["input"]
    output_cost = (output_tokens / 1_000_000) * pricing["output"]
    return input_cost + output_cost


def report_to_cloud_monitoring(input_tokens, output_tokens, estimated_cost):
    """Report metrics to GCP Cloud Monitoring."""
    if not HAS_CLOUD_MONITORING:
        logger.warning("google-cloud-monitoring not installed, skipping metric export")
        return

    client = monitoring_v3.MetricServiceClient()
    project_name = f"projects/{GCP_PROJECT_ID}"

    now = time.time()
    interval = monitoring_v3.TimeInterval(
        {"end_time": {"seconds": int(now), "nanos": 0}}
    )

    metrics = {
        "custom.googleapis.com/openclaw/input_tokens": float(input_tokens),
        "custom.googleapis.com/openclaw/output_tokens": float(output_tokens),
        "custom.googleapis.com/openclaw/estimated_cost_usd": estimated_cost,
    }

    for metric_type, value in metrics.items():
        series = monitoring_v3.TimeSeries()
        series.metric.type = metric_type
        series.resource.type = "gce_instance"
        series.resource.labels["project_id"] = GCP_PROJECT_ID

        point = monitoring_v3.Point(
            {"interval": interval, "value": {"double_value": value}}
        )
        series.points = [point]

        try:
            client.create_time_series(
                request={"name": project_name, "time_series": [series]}
            )
        except Exception as e:
            logger.error("Failed to write metric %s: %s", metric_type, e)


def main():
    """Main loop: collect metrics and report at configured interval."""
    logger.info(
        "Starting OpenClaw cost tracker (interval=%ds, project=%s)",
        INTERVAL, GCP_PROJECT_ID,
    )

    while True:
        try:
            input_tokens, output_tokens = get_token_usage_from_logs()
            estimated_cost = estimate_cost(input_tokens, output_tokens)

            logger.info(
                "Tokens - input: %d, output: %d, estimated cost: $%.6f",
                input_tokens, output_tokens, estimated_cost,
            )

            report_to_cloud_monitoring(input_tokens, output_tokens, estimated_cost)

        except Exception as e:
            logger.error("Error in cost tracking loop: %s", e)

        time.sleep(INTERVAL)


if __name__ == "__main__":
    main()
