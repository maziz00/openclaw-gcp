[Unit]
Description=OpenClaw Claude API Cost Tracker
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/openclaw/cost-tracker.py
Restart=always
RestartSec=10
User=root
StandardOutput=append:{{ cost_tracker_log }}
StandardError=append:{{ cost_tracker_log }}

[Install]
WantedBy=multi-user.target
