# OpenClaw Environment Configuration
# Managed by Ansible - do not edit manually

{% if claude_provider == "anthropic_api" %}
# Anthropic API Key
ANTHROPIC_API_KEY={{ _anthropic_key.content | b64decode | trim }}
{% endif %}

{% if claude_provider == "vertex_ai" %}
# Vertex AI: OpenClaw uses google-vertex provider via ADC (no API key needed).
# Provider is configured in openclaw.json, not via env vars.
GOOGLE_CLOUD_PROJECT={{ gcp_project_id }}
{% endif %}

{% if openclaw_channels.telegram | default(false) %}
# Telegram Bot Token
TELEGRAM_BOT_TOKEN={{ _telegram_token.content | b64decode | trim }}
{% endif %}

{% if openclaw_channels.discord | default(false) %}
# Discord Bot Token
DISCORD_BOT_TOKEN={{ _discord_token.content | b64decode | trim }}
{% endif %}

# Application Settings
NODE_ENV=production
