# OpenClaw Environment Configuration
# Managed by Ansible - do not edit manually

# Claude Provider: {{ claude_provider }}
CLAUDE_PROVIDER={{ claude_provider }}

{% if claude_provider == "anthropic_api" %}
# Anthropic API Key (fetched from Secret Manager by secrets role)
ANTHROPIC_API_KEY={{ anthropic_api_key.stdout }}
{% endif %}

{% if claude_provider == "vertex_ai" %}
# Vertex AI Configuration
# Authentication via the VM's attached service account (ADC) — no credentials file needed.
VERTEX_AI_PROJECT={{ gcp_project_id }}
VERTEX_AI_LOCATION=us-central1
{% endif %}

{% if openclaw_channels.telegram | default(false) %}
# Telegram Bot Token (fetched from Secret Manager by secrets role)
TELEGRAM_BOT_TOKEN={{ telegram_bot_token.stdout }}
{% endif %}

{% if openclaw_channels.discord | default(false) %}
# Discord Bot Token (fetched from Secret Manager by secrets role)
DISCORD_BOT_TOKEN={{ discord_bot_token.stdout }}
{% endif %}

# Application Settings
NODE_ENV=production
PORT=3000
